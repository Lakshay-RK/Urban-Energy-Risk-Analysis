# ============================================================
# ADVANCED URBAN ENERGY RISK ANALYSIS SYSTEM
# ============================================================

# =======================
# IMPORT LIBRARIES
# =======================

import numpy as np
import pandas as pd

# Spatial
import libpysal
from libpysal.weights import lat2W, KNN, Queen
from esda.moran import Moran, Moran_Local
from esda.geary import Geary

# Spatial Regression
from spreg import ML_Lag, ML_Error, OLS

# Machine Learning
from sklearn.preprocessing import StandardScaler, MinMaxScaler
from sklearn.decomposition import PCA
from sklearn.cluster import KMeans, DBSCAN
from sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor
from sklearn.linear_model import LinearRegression
from sklearn.model_selection import train_test_split, GridSearchCV
from sklearn.metrics import mean_squared_error, r2_score

# Deep Learning
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, Dropout

# Stats
from scipy import stats

# Visualization
import matplotlib.pyplot as plt
import seaborn as sns

# Others
import itertools
import warnings
warnings.filterwarnings("ignore")

# ============================================================
# GLOBAL CONFIGURATION
# ============================================================

np.random.seed(42)

GRID_SIZE = 25
N = GRID_SIZE ** 2

# ============================================================
# DATA GENERATION MODULE
# ============================================================

def generate_city_grid(size):
    x, y = np.indices((size, size))
    return x, y

def generate_urban_features(x, y):
    center = (x.mean(), y.mean())
    dist = np.sqrt((x - center[0])**2 + (y - center[1])**2)

    income = 60000 + dist * 3000 + np.random.normal(0, 4000, x.shape)
    building_age = 70 - dist * 5 + np.random.normal(0, 7, x.shape)
    population_density = 1200 + (1/(dist+1))*600 + np.random.normal(0, 60, x.shape)
    green_space = np.maximum(0, 60 - dist*2 + np.random.normal(0, 8, x.shape))
    industrial = np.random.uniform(0, 120, x.shape)
    temperature = 25 + dist * 0.8 + np.random.normal(0, 1, x.shape)

    return {
        "income": income,
        "building_age": building_age,
        "density": population_density,
        "green": green_space,
        "industrial": industrial,
        "temperature": temperature,
        "distance": dist
    }

def generate_energy_risk(features):
    risk = (
        features["building_age"] * 0.7
        - features["income"] * 0.0005
        + features["density"] * 0.003
        - features["green"] * 0.12
        + features["industrial"] * 0.06
        + features["temperature"] * 1.2
        + 25
    )
    noise = np.random.normal(0, 2, risk.shape)
    return (risk + noise).flatten()

# ============================================================
# FEATURE ENGINEERING
# ============================================================

def flatten_features(features):
    return pd.DataFrame({k: v.flatten() for k, v in features.items()})

def engineer_features(df):
    df["income_age"] = df["income"] * df["building_age"]
    df["density_green"] = df["density"] / (df["green"] + 1)
    df["heat_index"] = df["temperature"] * df["density"]
    df["industrial_pressure"] = df["industrial"] * df["density"]
    df["socio_index"] = df["income"] / (df["density"] + 1)
    return df

# ============================================================
# SCALING
# ============================================================

def scale_data(df):
    scaler = StandardScaler()
    scaled = scaler.fit_transform(df)
    return scaled, scaler

# ============================================================
# SPATIAL WEIGHTS
# ============================================================

def create_weights(grid):
    w1 = lat2W(grid, grid)
    w1.transform = 'R'

    coords = [(i, j) for i in range(grid) for j in range(grid)]
    w2 = KNN.from_array(coords, k=5)
    w2.transform = 'R'

    w3 = Queen.from_array(np.ones((grid, grid)))
    w3.transform = 'R'

    return w1, w2, w3

# ============================================================
# SPATIAL ANALYSIS
# ============================================================

def spatial_statistics(y, w):
    moran = Moran(y, w)
    geary = Geary(y, w)

    return {
        "Moran_I": moran.I,
        "Moran_p": moran.p_sim,
        "Geary_C": geary.C,
        "Geary_p": geary.p_sim
    }

def local_spatial(y, w):
    return Moran_Local(y, w)

# ============================================================
# MACHINE LEARNING MODELS
# ============================================================

def train_ml_models(X, y):
    X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)

    models = {
        "Linear": LinearRegression(),
        "RF": RandomForestRegressor(n_estimators=100),
        "GB": GradientBoostingRegressor()
    }

    results = {}

    for name, model in models.items():
        model.fit(X_train, y_train)
        pred = model.predict(X_test)

        results[name] = {
            "RMSE": np.sqrt(mean_squared_error(y_test, pred)),
            "R2": r2_score(y_test, pred)
        }

    return results

# ============================================================
# DEEP LEARNING MODEL
# ============================================================

def build_nn(input_dim):
    model = Sequential()
    model.add(Dense(128, activation='relu', input_dim=input_dim))
    model.add(Dropout(0.3))
    model.add(Dense(64, activation='relu'))
    model.add(Dense(1))

    model.compile(optimizer='adam', loss='mse')
    return model

# ============================================================
# SPATIAL REGRESSION
# ============================================================

def run_spatial_models(X, y, w):
    y_vec = y.reshape(-1, 1)

    ols = OLS(y_vec, X)
    lag = ML_Lag(y_vec, X, w=w)
    err = ML_Error(y_vec, X, w=w)

    return ols, lag, err

# ============================================================
# PCA
# ============================================================

def apply_pca(X):
    pca = PCA(n_components=5)
    return pca.fit_transform(X)

# ============================================================
# CLUSTERING
# ============================================================

def clustering(X):
    kmeans = KMeans(n_clusters=5)
    db = DBSCAN(eps=0.5)

    return kmeans.fit_predict(X), db.fit_predict(X)

# ============================================================
# MONTE CARLO
# ============================================================

def monte_carlo(features, iterations=30):
    values = []

    for _ in range(iterations):
        y = generate_energy_risk(features)
        w, _, _ = create_weights(GRID_SIZE)
        stats = spatial_statistics(y, w)
        values.append(stats["Moran_I"])

    return values

# ============================================================
# VISUALIZATION
# ============================================================

def plot_heatmap(data, title):
    plt.figure(figsize=(6, 6))
    sns.heatmap(data, cmap="viridis")
    plt.title(title)
    plt.show()

def plot_hist(data):
    plt.hist(data, bins=20)
    plt.title("Monte Carlo Distribution")
    plt.show()

# ============================================================
# RESIDUAL ANALYSIS
# ============================================================

def analyze_residuals(model, y):
    residuals = y.flatten() - model.predy.flatten()

    print("Residual Mean:", np.mean(residuals))
    print("Skew:", stats.skew(residuals))
    print("Kurtosis:", stats.kurtosis(residuals))

# ============================================================
# GRID SEARCH (HYPERPARAMETER)
# ============================================================

def hyperparameter_tuning(X, y):
    model = RandomForestRegressor()

    params = {
        "n_estimators": [50, 100],
        "max_depth": [5, 10]
    }

    grid = GridSearchCV(model, params, cv=3)
    grid.fit(X, y)

    return grid.best_params_

# ============================================================
# MAIN PIPELINE
# ============================================================

def main():

    # Generate grid
    x, y = generate_city_grid(GRID_SIZE)

    # Features
    features = generate_urban_features(x, y)

    # Target
    energy_risk = generate_energy_risk(features)

    # DataFrame
    df = flatten_features(features)

    # Feature Engineering
    df = engineer_features(df)

    # Scaling
    X_scaled, scaler = scale_data(df)

    # PCA
    X_pca = apply_pca(X_scaled)

    # Spatial Weights
    w1, w2, w3 = create_weights(GRID_SIZE)

    # Spatial Stats
    stats1 = spatial_statistics(energy_risk, w1)
    print("Spatial Stats:", stats1)

    # Models
    ols, lag, err = run_spatial_models(df.values, energy_risk, w1)

    print("\n--- Spatial Lag ---")
    print(lag.summary)

    # ML Models
    ml_results = train_ml_models(X_scaled, energy_risk)
    print("\nML Results:", ml_results)

    # Deep Learning
    nn = build_nn(X_scaled.shape[1])
    nn.fit(X_scaled, energy_risk, epochs=5, verbose=0)

    # Clustering
    k_labels, d_labels = clustering(X_pca)

    # Monte Carlo
    mc = monte_carlo(features)
    print("MC Mean:", np.mean(mc))

    # Visualization
    plot_heatmap(energy_risk.reshape(GRID_SIZE, GRID_SIZE), "Energy Risk")
    plot_hist(mc)

    # Residuals
    analyze_residuals(lag, energy_risk)

    # Hyperparameter tuning
    best_params = hyperparameter_tuning(X_scaled, energy_risk)
    print("Best Params:", best_params)

# ============================================================
# EXECUTION
# ============================================================

if __name__ == "__main__":
    main()

# ============================================================
# END
# ============================================================
